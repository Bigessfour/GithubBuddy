{
  "name": "githubbuddy",
  "description": "Platoon Companion — Code Platoon GitHub workflow learning app (web + Electron desktop).",
  "license": "MIT",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "playwright test e2e/visual/inventory.spec.ts",
    "test:e2e:update-snapshots": "playwright test e2e/visual/screenshots.spec.ts --update-snapshots",
    "vite:version": "vite --version",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:clean": "node -e \"const fs=require('fs');['out','dist-electron'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});}catch(e){}})\"",
    "electron:preview": "cross-env NODE_ENV=production electron .",
    "setup-course": "node scripts/setup-course.js",
    "postinstall": "node scripts/setup-course.js --auto"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.5"
  }
}
